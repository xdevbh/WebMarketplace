@using Microsoft.Extensions.Localization
@using Volo.Abp.Users
@using Volo.Abp.MultiTenancy
@using global::Localization.Resources.AbpUi
@inherits AbpComponentBase
@inject ICurrentUser CurrentUser
@inject ICurrentTenant CurrentTenant
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<AbpUiResource> UiLocalizer

<AuthorizeView>
    <Authorized>
        <MudMenu Color="MudBlazor.Color.Inherit" Direction="MudBlazor.Direction.Left" OffsetX="true" Dense="true">
            <ActivatorContent>
                <MudButton Variant="Variant.Text"
                           Color="MudBlazor.Color.Inherit"
                           StartIcon="@Icons.Material.Filled.AccountCircle">
                    @CurrentUser.Name
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                @if (Menu is not null && Menu.Items.Any())
                {
                    @foreach (var menuItem in Menu.Items)
                    {
                        <MudListItem Icon="@Icons.Material.Outlined.AccountCircle"
                                     OnClick="@(async () => await NavigateToAsync(menuItem.Url, menuItem.Target))">
                            @menuItem.DisplayName
                        </MudListItem>
                    }

                    <MudDivider/>
                }
                <MudListItem Icon="@Icons.Material.Outlined.Logout" OnClick="BeginSignOut">
                    @UiLocalizer["Logout"]
                </MudListItem>
            </ChildContent>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <MudLink Color="MudBlazor.Color.Inherit" Href="authentication/login">
            <MudButton Variant="Variant.Text"
                       Color="MudBlazor.Color.Inherit"
                       StartIcon="@Icons.Material.Filled.Login">
                @UiLocalizer["Login"]
            </MudButton>
        </MudLink>
    </NotAuthorized>
</AuthorizeView>